# Backend signer (signs purchase vouchers)
SIGNER_PRIVATE_KEY=your_signer_private_key_here

# NFT Contract
NFT_CONTRACT_ADDRESS=your_nft_contract_address_here

# Admin addresses (comma-separated, lowercase)
ADMIN_ADDRESSES=0xyour_admin_address_here

# Paid game: treasury address receives ETH payments
# Price in wei: 3000000000000 = 0.000003 ETH ≈ $0.01 at ~$3333/ETH
TREASURY_ADDRESS=0xyour_treasury_address_here
PAID_GAME_PRICE_WEI=3000000000000
