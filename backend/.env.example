PORT=8787
ALLOWED_ORIGIN=http://localhost:4000
SESSION_TTL_MS=600000
MAX_DURATION_MS=300000
DATABASE_URL=
PG_SSL=true
AUTH_NONCE_TTL_MS=600000
JWT_SECRET=
JWT_EXPIRES=7d
APP_URL=https://rugpullrun.app
BASE_API_KEY=
PAYMASTER_URL=

# Blockchain Configuration
# Most on-chain reads use the hardcoded public RPC (mainnet.base.org + fallbacks).
# LEADERBOARD_RPC_URL is used ONLY for the basename batch in refreshLeaderboard,
# which fires ~200 sequential calls every 12h — set this to a paid endpoint
# (e.g. Ankr) to avoid public-RPC rate limiting. Falls back to RPC_URL, then
# to the public endpoint. RPC_URL is kept only for backward compat.
LEADERBOARD_RPC_URL=
RPC_URL=https://mainnet.base.org
CHAIN_ID=8453

# Backend signer (signs purchase vouchers)
SIGNER_PRIVATE_KEY=

# NFT Contract
NFT_CONTRACT_ADDRESS=your_nft_contract_address_here

# GameCoin / upgrade contracts
GAME_COIN_ADDRESS=your_gamecoin_contract_address_here
CHARACTER_UPGRADE_ADDRESS=your_character_upgrade_contract_address_here
MINTER_PRIVATE_KEY=

# Admin addresses (comma-separated, lowercase)
ADMIN_ADDRESSES=0xyour_admin_address_here

# Paid game: treasury address receives ETH payments
# Price in wei: 3000000000000 = 0.000003 ETH ≈ $0.01 at ~$3333/ETH
TREASURY_ADDRESS=0xyour_treasury_address_here
PAID_GAME_PRICE_WEI=3000000000000
